# Site URL (no trailing slash). Used for canonical URLs, sitemap, robots, Open Graph.
NEXT_PUBLIC_SITE_URL=

# Google Tag Manager container ID, e.g. GTM-XXXXXXX
NEXT_PUBLIC_GTM_ID=

# GA4 measurement ID, e.g. G-XXXXXXXXXX
NEXT_PUBLIC_GA4_ID=

# Google Ads conversion ID, e.g. AW-XXXXXXXXX
NEXT_PUBLIC_GOOGLE_ADS_ID=

# Google Ads conversion labels (from each conversion action)
NEXT_PUBLIC_GOOGLE_ADS_FORM_CONVERSION_LABEL=
NEXT_PUBLIC_GOOGLE_ADS_PHONE_CONVERSION_LABEL=
NEXT_PUBLIC_GOOGLE_ADS_WHATSAPP_CONVERSION_LABEL=
NEXT_PUBLIC_GOOGLE_ADS_BOOKING_CONVERSION_LABEL=
NEXT_PUBLIC_GOOGLE_ADS_QUOTE_CONVERSION_LABEL=

# Meta (Facebook) Pixel ID
NEXT_PUBLIC_META_PIXEL_ID=

# TikTok Pixel ID (placeholder support)
NEXT_PUBLIC_TIKTOK_PIXEL_ID=

# Master switch. Set to "true" in production once IDs are configured.
NEXT_PUBLIC_ENABLE_TRACKING=false
